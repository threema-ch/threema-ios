# Excluded files

## Generated files
--exclude **/*.pb.swift # Protobuf
--exclude **/ColorDefines.swift # Colors
--exclude **/SnapshotHelper.swift

## Vendored code
--exclude DerivedData/**
--exclude fastlane/**
--exclude libthreemaSwift/Sources/libthreemaSwift/Generated/**
--exclude NaClCrypto/**
--exclude protobuf/**
--exclude SaltyRTC/**
--exclude **/DerivedData
--exclude Vendor/**
--exclude WebRTC**
--exclude export/**

## Other files
--exclude scripts/format/.build/checkouts/SwiftFormat/CommandLineTool/swiftformat
--exclude scripts/format/.build/checkouts/SwiftFormat/Sources/Info.plist

# Format options

--asynccapturing XCTAssertThrowsAsyncError
--elseposition next-line
--emptybraces spaced
--extensionacl on-declarations
--groupedextension "MARK: - %c"
--header strip
--importgrouping testable-last
--indentstrings true
--marktypes never
--maxwidth 120
--ranges no-space
--propertytypes inferred
--self init-only
--semicolons never
--stripunusedargs closure-only
--trimwhitespace nonblank-lines # Waiting for https://github.com/nicklockwood/SwiftFormat/issues/1664
--wraparguments before-first
--wrapcollections before-first
--wrapparameters before-first

# Rules

--enable acronyms
--enable blockComments
--enable isEmpty
--enable markTypes
--enable wrapConditionalBodies
--enable wrapMultilineConditionalAssignment

--disable blankLinesAtStartOfScope # Waiting for https://github.com/nicklockwood/SwiftFormat/issues/583
--disable sortTypealiases
--disable wrapMultilineStatementBraces

# Disabling new defaults from 0.54.1+

## Disabled in order to match current setup
--disable redundantLet
--disable redundantSelf
--disable wrap
--disable trailingcommas
--disable trailingClosures
--disable swiftTestingTestCaseNames
--disable redundantSwiftTestingSuite
--disable redundantEmptyView
--disable redundantType
--disable blankLinesAroundMark
--disable redundantNilInit
--disable redundantVoidReturnType

## New default rules in 0.55.0+
--disable docCommentsBeforeModifiers
--disable unusedPrivateDeclarations
--disable propertyTypes

## New default rules in 0.56.0+
--disable wrapMultilineFunctionChains
--disable preferCountWhere
--disable blankLinesAfterGuardStatements
--disable privateStateVariables

## New default rules in 0.57.0+
--disable singlePropertyPerLine
--disable redundantPublic
--disable modifiersOnSameLine

## New default rules in 0.58.0+
--disable preferFinalClasses

## New default rules in 0.59.0+
--disable blankLinesBetweenImports
--disable docComments
--disable emptyExtensions
--disable environmentEntry
--disable noForceTryInTests
--disable noForceUnwrapInTests
--disable redundantAsync
--disable redundantEquatable
--disable redundantMemberwiseInit
--disable redundantVariable
--disable redundantViewBuilder
--disable redundantThrows
--disable simplifyGenericConstraints
--disable wrapPropertyBodies
--disable wrapFunctionBodies

## New default rules in 0.60.0+
--disable redundantSendable
--disable preferExplicitFalse
